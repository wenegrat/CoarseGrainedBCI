#!/bin/bash -l
#PBS -A UMCP0023
#PBS -N bci_sweep_filter
#PBS -o logs/bci_sweep_filter.log
#PBS -e logs/bci_sweep_filter.log
# Note: job name above is a default; qalter below updates it at runtime based on Nx/Ny/Nz
# Log file paths (-o/-e) cannot be changed at runtime; use the .out file for per-run logs
#PBS -l walltime=23:59:00
#PBS -q casper
#PBS -M wenegrat@umd.edu
#PBS -m ae
#PBS -r n
#PBS -l select=1:ncpus=8:mem=384GB:ngpus=0
#PBS -l job_priority=regular

# Many-filter-scale sweep, step 1 of 2 (see CLAUDE.md: sweep1's --scale-min/--scale-max/--n-scales
# default to a data-driven range now, not a hardcoded KH-unit range).
set -eo pipefail

NX=${NX:-192}
NY=${NY:-192}
NZ=${NZ:-32}
N_TIME_SKIP=${N_TIME_SKIP:-1}
SIM=bci_Nx${NX}_Ny${NY}_Nz${NZ}
JOB_NAME="${SIM}_sweep_filter"
qalter -N "$JOB_NAME" "$PBS_JOBID"

source ../hpc_env.sh

time $PYTHON -u sweep1_filter_fields.py --filename output/${SIM}.nc --n-time-skip $N_TIME_SKIP 2>&1 | tee logs/${JOB_NAME}.out

qstat -f $PBS_JOBID >> logs/${JOB_NAME}.out
