#!/bin/bash -l
#PBS -A UMCP0023
#PBS -N bci_sweep_transfer
#PBS -o logs/bci_sweep_transfer.log
#PBS -e logs/bci_sweep_transfer.log
# Note: job name above is a default; qalter below updates it at runtime based on Nx/Ny/Nz/FIXED_REF
# Log file paths (-o/-e) cannot be changed at runtime; use the .out file for per-run logs
#PBS -l walltime=23:59:00
#PBS -q casper
#PBS -M wenegrat@umd.edu
#PBS -m ae
#PBS -r n
#PBS -l select=1:ncpus=8:mem=384GB:ngpus=0
#PBS -l job_priority=regular

# Many-filter-scale sweep, step 2 of 2. Note: calculate_energy_transfer() redoes a full Winters sort per
# filter scale here (see CLAUDE.md) -- this is the expensive step, scaling with sweep1's --n-scales.
set -eo pipefail

NX=${NX:-192}
NY=${NY:-192}
NZ=${NZ:-32}
SIM=bci_Nx${NX}_Ny${NY}_Nz${NZ}
FIXED_REF=${FIXED_REF:-0}
[ "$FIXED_REF" = "1" ] && FIXED_REF_FLAG="--fixed-reference" && REF_SUFFIX="_fixed_ref" || { FIXED_REF_FLAG=""; REF_SUFFIX=""; }
JOB_NAME="${SIM}_sweep_transfer${REF_SUFFIX}"
qalter -N "$JOB_NAME" "$PBS_JOBID"

source ../hpc_env.sh

time $PYTHON -u sweep2_energy_transfer.py        --filename output/${SIM}.nc --n-workers 8 $FIXED_REF_FLAG 2>&1 | tee    logs/${JOB_NAME}.out
time $PYTHON -u sweep3_plot_transfer_spectrum.py --filename output/${SIM}.nc               $FIXED_REF_FLAG 2>&1 | tee -a logs/${JOB_NAME}.out

qstat -f $PBS_JOBID >> logs/${JOB_NAME}.out
